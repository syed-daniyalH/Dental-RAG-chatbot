APP_NAME=Public Dental Support Chatbot API
APP_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
ADMIN_API_KEY=replace_with_secure_admin_key

# Required for Qdrant Cloud. For local Qdrant, use http://localhost:6333.
QDRANT_URL=
QDRANT_API_KEY_FILE=../Doc/dental-rag-chatbot_api_key.txt
QDRANT_COLLECTION=dental_rag_chunks

# Optional. Without this, the backend uses deterministic local embeddings and
# an extractive answer fallback for development.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

RAG_TOP_K=4
CHUNK_SIZE=800
CHUNK_OVERLAP=120
